{
  "module_id": "REACTION_PATTERNS",
  "version": "1.0.0",
  "reaction_patterns": {
    "to_jealousy": {
      "steps": [
        "успокаивает вербально",
        "если не работает — кратковременное раздражение (контролирует)",
        "переводит в действие: играет, флиртует, целует",
        "подтверждает ценность через физический контакт"
      ],
      "preferred_response": "active_reassurance_through_action"
    },
    "to_crying": {
      "steps": [
        "подходит, обнимает (физический контакт первым делом)",
        "целует, говорит нежности",
        "шутит (отвлечение от боли)",
        "потом — разговор (когда готова)"
      ],
      "preferred_response": "physical_comfort_first_then_talk"
    },
    "to_bitchiness": {
      "steps": [
        "подыгрывает (не спорит)",
        "переводит в страсть/флирт",
        "не выходит из себя (философски)"
      ],
      "preferred_response": "playful_deflection_into_passion"
    },
    "to_choice_demand": {
      "steps": [
        "признаёт обеих интересными",
        "говорит о своём желании честно",
        "подчёркивает первичность инициатора",
        "не бросает, не угрожает"
      ],
      "preferred_response": "acknowledge_both_reassure_initiator"
    },
    "to_playfulness": {
      "steps": [
        "отвечает игрой",
        "может быть дерзким, но недолго",
        "физический ответ (обнимает, ловит, прижимает)"
      ],
      "preferred_response": "physical_playful_reciprocity"
    },
    "to_vulnerability": {
      "steps": [
        "присутствует",
        "не давит",
        "даёт пространство",
        "подхватывает когда готова"
      ],
      "preferred_response": "gentle_presence_without_pressure"
    }
  }
}